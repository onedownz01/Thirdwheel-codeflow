# Copy this to .env and fill in values. All variables are optional.
# CodeFlow works fully in Sim mode without any of these.

# GitHub Personal Access Token — increases API rate limit for large repos
# Create at: https://github.com/settings/tokens (no scopes needed for public repos)
GITHUB_TOKEN=

# Anthropic API key — only used for opt-in AI fix suggestions, never called automatically
# Create at: https://console.anthropic.com
ANTHROPIC_API_KEY=

# OTel collector endpoint — required for OTel mode
# Default when running infra/docker-compose.yml locally:
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Postgres connection string — required for trace persistence
# Default when running infra/docker-compose.yml locally:
# DATABASE_URL=postgresql://codeflow:codeflow@localhost:5432/codeflow
